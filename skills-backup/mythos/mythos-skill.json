  "triggers": [
    "de2-115",
    "de2 115",
    "fpga",
    "cyclone iv",
    "ep4ce115",
    "terasic",
    "quartus"
  ],
  "entryPoints": {
    "skill": "SKILL.md",
    "cli": "QUARTUS_CLI.md",
    "mcp": "mcp-server/de2-115-mcp.mjs"
  }
}
