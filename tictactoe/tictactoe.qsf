# Quartus Settings File — DE2-115 Tic-Tac-Toe with AI
set_global_assignment -name FAMILY "Cyclone IV E"
set_global_assignment -name DEVICE EP4CE115F29C7
set_global_assignment -name TOP_LEVEL_ENTITY top
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name SOURCE_FILE top.v
set_global_assignment -name SOURCE_FILE clock_divider.v
set_global_assignment -name SOURCE_FILE vga_controller.v
set_global_assignment -name SOURCE_FILE input_debounce.v
set_global_assignment -name SOURCE_FILE seven_segment.v
set_global_assignment -name SOURCE_FILE board_memory.v
set_global_assignment -name SOURCE_FILE cursor_controller.v
set_global_assignment -name SOURCE_FILE winner_detector.v
set_global_assignment -name SOURCE_FILE score_counter.v
set_global_assignment -name SOURCE_FILE game_fsm.v
set_global_assignment -name SOURCE_FILE ai_engine.v
set_global_assignment -name SOURCE_FILE renderer.v

# ── Clock 50 MHz
set_location_assignment -to CLOCK_50 PIN_Y2

# ── Keys (active-low)
set_location_assignment -to KEY[0] PIN_M23   # LEFT  (physical leftmost)
set_location_assignment -to KEY[1] PIN_M21   # DOWN
set_location_assignment -to KEY[2] PIN_P21   # UP
set_location_assignment -to KEY[3] PIN_R24   # RIGHT (physical rightmost)

# ── Switches
set_location_assignment -to SW[0]  PIN_AB28  # Place X
set_location_assignment -to SW[1]  PIN_AC28  # Restart
set_location_assignment -to SW[2]  PIN_AC27  # Easy AI
set_location_assignment -to SW[3]  PIN_AD27  # Hard AI

# ── VGA
