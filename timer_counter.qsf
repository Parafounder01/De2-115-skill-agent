# Quartus Settings File — DE2-115 Timer (HEX3..HEX0 format 00.00)
set_global_assignment -name FAMILY "Cyclone IV E"
set_global_assignment -name DEVICE EP4CE115F29C7
set_global_assignment -name TOP_LEVEL_ENTITY timer_counter
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name SOURCE_FILE timer_counter.v

# ── Clock & Reset ──────────────────────────────────────────
set_location_assignment -to clk   PIN_Y2    # CLOCK_50 (50 MHz)
set_location_assignment -to rst_n PIN_M23   # KEY[0] (active-low)

# ── HEX0 (hundredths) ─────────────────────────────────────
set_location_assignment -to hex0[0] PIN_G18
set_location_assignment -to hex0[1] PIN_F22
set_location_assignment -to hex0[2] PIN_E17
set_location_assignment -to hex0[3] PIN_L26
set_location_assignment -to hex0[4] PIN_L25
set_location_assignment -to hex0[5] PIN_J22
set_location_assignment -to hex0[6] PIN_H22

# ── HEX1 (tenths) ─────────────────────────────────────────
set_location_assignment -to hex1[0] PIN_M24
set_location_assignment -to hex1[1] PIN_Y22
set_location_assignment -to hex1[2] PIN_W21
set_location_assignment -to hex1[3] PIN_W22
set_location_assignment -to hex1[4] PIN_W25
set_location_assignment -to hex1[5] PIN_U23
set_location_assignment -to hex1[6] PIN_U24

# ── HEX2 (seconds ones) ───────────────────────────────────
set_location_assignment -to hex2[0] PIN_AA25
set_location_assignment -to hex2[1] PIN_AA26
set_location_assignment -to hex2[2] PIN_Y25
set_location_assignment -to hex2[3] PIN_W26
set_location_assignment -to hex2[4] PIN_Y26
set_location_assignment -to hex2[5] PIN_W27
set_location_assignment -to hex2[6] PIN_W28

# ── HEX3 (seconds tens) ───────────────────────────────────
set_location_assignment -to hex3[0] PIN_V21
set_location_assignment -to hex3[1] PIN_U21
set_location_assignment -to hex3[2] PIN_AB20
set_location_assignment -to hex3[3] PIN_AA21
set_location_assignment -to hex3[4] PIN_AD24
set_location_assignment -to hex3[5] PIN_AF23
set_location_assignment -to hex3[6] PIN_Y19

set_global_assignment -name LAST_QUARTUS_VERSION 10.0